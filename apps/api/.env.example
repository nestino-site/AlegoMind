# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://alegomind:alegomind_dev@localhost:5432/alegomind

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token — short-lived (15 minutes)
# Generate: openssl rand -base64 48
JWT_SECRET=your-access-token-secret-change-in-production
JWT_EXPIRES_IN=15m

# Refresh token — long-lived (30 days), different secret
# Generate: openssl rand -base64 48
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Optional — OTP codes are always logged to console in development
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@alegomind.ro

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_HEALTH_PLUS_PRICE_ID=price_...

# ─── Anthropic (AI matching) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Platform ─────────────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=0.20
