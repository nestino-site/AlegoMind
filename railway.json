{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "yarn install --frozen-lockfile && yarn workspace @alegomind/api prisma:generate && yarn workspace @alegomind/api build"
  },
  "deploy": {
    "startCommand": "yarn workspace @alegomind/api prisma:migrate:deploy && node apps/api/dist/main",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
