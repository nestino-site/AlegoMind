# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ─── Database ─────────────────────────────────────────────────────────────────
# Railway PostgreSQL connection string — copy from Railway dashboard
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave commented in development — OTP codes are logged to console instead
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM="AlegoMind <noreply@alegomind.ro>"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# AlegoMind Plus subscription Stripe Price ID
STRIPE_HEALTH_PLUS_PRICE_ID=price_...

# ─── Anthropic (AI matching) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Platform ─────────────────────────────────────────────────────────────────
# Percentage fee taken from each booking (0.20 = 20%)
PLATFORM_FEE_PERCENT=0.20
